{
  "name": "LicenseKey",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": ["script", "internal"],
      "default": "script"
    },
    "internal_key": {
      "type": "string"
    },
    "script_key": {
      "type": "string"
    },
    "key": {
      "type": "string",
      "description": "The license key string (alias for script_key)"
    },
    "used": {
      "type": "boolean",
      "default": false
    },
    "used_by_username": {
      "type": "string"
    },
    "used_at": {
      "type": "string",
      "format": "date-time"
    },
    "note": {
      "type": "string"
    },
    "created_date": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "script_key",
    "key"
  ]
}
